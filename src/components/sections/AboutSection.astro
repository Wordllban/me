---
import SectionHeader from "./SectionHeader.astro";
import { facts } from "../../data/portfolio";
---

<div class="section" data-section="about" data-active>
  <SectionHeader
    title="Engineer and founder. Gardener off the clock."
    rune="I · The Origin"
  />
  <div
    data-body
    data-about-body
    style="flex:1;min-height:0;overflow:hidden;display:flex;flex-direction:column;gap:clamp(14px,2.2vh,24px)"
  >
    <div
      data-about-row
      style="flex:1;min-height:0;overflow:hidden;display:flex;gap:clamp(22px,3vw,40px);align-items:stretch"
    >
      <div style="flex:1;min-width:0;display:flex;flex-direction:column">
        <p style="color:var(--text-dim);margin:0 0 12px;line-height:1.65">
          I build products end to end — fullstack, increasingly with AI — and I
          co-founded
          <strong style="color:var(--text);font-weight:600">Ivy</strong>, a
          freelance, commission &amp; community platform for all forms of art.
          Six years in, across product teams and outstaff work, I care most
          about shipping things that genuinely help people.
        </p>
        <p style="color:var(--text-dim);margin:0 0 12px;line-height:1.65">
          I'm learning to lead with empathy, and to be openly fond of soft,
          cute, joyful things — a strength, not something to hide. I love
          Japan's design culture and its anime, and borrow their care for detail
          in everything I make.
        </p>
        <p style="color:var(--text-dim);margin:0;line-height:1.65">
          When I share what I make, it's not a flex — it's breadcrumbs, hoping
          to nudge someone else to start their own thing.
        </p>
        <div
          style="display:flex;flex-wrap:wrap;gap:8px;margin-top:auto;padding-top:18px"
        >
          {
            [
              "🌿 ivy & bonsai",
              "🎮 gaming",
              "🗾 japan & anime",
              "💜 purple",
            ].map((chip) => (
              <span style="font-family:var(--f-mono);font-size:11.5px;padding:6px 12px;border-radius:999px;background:var(--chip-bg);border:1px solid var(--border);color:var(--text-dim)">
                {chip}
              </span>
            ))
          }
        </div>
      </div>
      <div
        data-about-portrait
        class="tt"
        style="flex:0 0 clamp(250px,30vw,360px);position:relative;height:100%;min-height:150px;border-radius:var(--radius);border:1px dashed var(--border);background:repeating-linear-gradient(45deg,var(--panel-2) 0 11px,transparent 11px 22px);display:grid;place-items:center"
      >
        <span
          style="font-family:var(--f-mono);font-size:11.5px;color:var(--text-faint)"
          >[ portrait ]</span
        >
      </div>
    </div>

    <div
      style="flex:0 0 auto;position:relative;border:1px solid var(--border);border-radius:var(--radius);background:linear-gradient(180deg,rgba(124,77,255,.08),rgba(28,20,42,.4));padding:clamp(15px,1.7vw,20px) clamp(16px,1.8vw,22px);box-shadow:var(--shadow)"
      class="tt"
    >
      <span
        style="position:absolute;top:9px;left:9px;width:13px;height:13px;border-top:1.5px solid var(--gold);border-left:1.5px solid var(--gold);opacity:var(--bracket-op)"
      ></span>
      <span
        style="position:absolute;top:9px;right:9px;width:13px;height:13px;border-top:1.5px solid var(--gold);border-right:1.5px solid var(--gold);opacity:var(--bracket-op)"
      ></span>
      <span
        style="position:absolute;bottom:9px;left:9px;width:13px;height:13px;border-bottom:1.5px solid var(--gold);border-left:1.5px solid var(--gold);opacity:var(--bracket-op)"
      ></span>
      <span
        style="position:absolute;bottom:9px;right:9px;width:13px;height:13px;border-bottom:1.5px solid var(--gold);border-right:1.5px solid var(--gold);opacity:var(--bracket-op)"
      ></span>
      <div
        style="display:flex;align-items:center;justify-content:space-between;gap:12px;margin-bottom:16px"
      >
        <div style="display:flex;align-items:center;gap:9px">
          <svg
            viewBox="0 0 100 100"
            style="width:19px;height:19px;filter:drop-shadow(0 0 6px var(--leaf))"
            ><use href="#ivy-leaf"></use></svg
          >
          <span
            style="font-family:var(--f-display);font-size:15px;letter-spacing:.05em"
            >At a Glance</span
          >
        </div>
        <a
          href="/assets/kostiantyn-mininkov-cv.pdf"
          download
          style="font-family:var(--f-mono);font-size:10px;letter-spacing:.08em;text-transform:uppercase;color:var(--gold);text-decoration:none;border:1px solid var(--border);padding:6px 13px;border-radius:999px"
          class="tt">Download CV ↓</a
        >
      </div>
      <div
        data-facts-grid
        style="display:grid;grid-template-columns:repeat(5,1fr);gap:clamp(9px,1.2vw,14px)"
      >
        {
          facts.map((s) => (
            <div style="display:flex;flex-direction:column;align-items:flex-start;gap:5px;padding:13px 14px;border:1px solid var(--border);border-radius:var(--radius);background:linear-gradient(180deg,rgba(124,77,255,.07),transparent)">
              <span style="font-family:var(--f-mono);font-size:8.5px;letter-spacing:.14em;text-transform:uppercase;color:var(--gold)">
                {s.label}
              </span>
              <span style="font-family:var(--f-display);font-weight:600;font-size:clamp(17px,1.7vw,22px);line-height:1.05;color:var(--text)">
                {s.value}
              </span>
              <span style="font-family:var(--f-mono);font-size:9.5px;letter-spacing:.02em;color:var(--text-faint)">
                {s.sub}
              </span>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</div>
