---
import SectionHeader from "./SectionHeader.astro";
import { timeline, ventures } from "../../data/portfolio";
---

<div class="section" data-section="path">
  <SectionHeader
    title="Where I've grown."
    rune="II · The Path"
    marginBottom="22px"
  />
  <div
    data-body
    data-path-grid
    style="flex:1;min-height:0;overflow-y:auto;padding-right:6px;padding-left:10px;display:grid;grid-template-columns:1fr 1fr;gap:clamp(22px,3vw,48px);align-content:start"
  >
    <!-- Corporate -->
    <div>
      <div style="display:flex;align-items:center;gap:11px;margin-bottom:20px">
        <svg
          viewBox="0 0 100 100"
          style="width:16px;height:16px;flex:0 0 auto;filter:drop-shadow(0 0 6px var(--leaf))"
          ><use href="#ivy-leaf"></use></svg
        >
        <span
          style="font-family:var(--f-mono);font-size:10px;letter-spacing:.2em;text-transform:uppercase;color:var(--gold)"
          >Corporate · the craft</span
        >
        <span
          style="flex:1;height:1px;background:linear-gradient(90deg,var(--border),transparent)"
        ></span>
      </div>
      <div
        style="border-left:2px solid var(--border);padding-left:26px;margin-left:6px"
      >
        {
          timeline.map((job) => (
            <div style="position:relative;padding:0 0 24px">
              <svg
                viewBox="0 0 100 100"
                style="position:absolute;left:-36px;top:1px;width:18px;height:18px"
              >
                <use href="#ivy-leaf" />
              </svg>
              <div style="font-family:var(--f-mono);font-size:11.5px;color:var(--accent-2);margin-bottom:4px">
                {job.years}
              </div>
              <div style="font-family:var(--f-display);font-size:18px">
                {job.role}{" "}
                <span style="color:var(--text-faint)">· {job.org}</span>
              </div>
              <p style="color:var(--text-dim);margin:6px 0 0;font-size:13.5px;line-height:1.6">
                {job.note}
              </p>
            </div>
          ))
        }
      </div>
    </div>

    <!-- Entrepreneurship -->
    <div>
      <div style="display:flex;align-items:center;gap:11px;margin-bottom:20px">
        <svg
          viewBox="0 0 100 100"
          style="width:16px;height:16px;flex:0 0 auto;--leaf:var(--accent);filter:drop-shadow(0 0 7px var(--accent))"
          ><use href="#ivy-leaf"></use></svg
        >
        <span
          style="font-family:var(--f-mono);font-size:10px;letter-spacing:.2em;text-transform:uppercase;color:var(--accent)"
          >Venture · the founder</span
        >
        <span
          style="flex:1;height:1px;background:linear-gradient(90deg,var(--border-2),transparent)"
        ></span>
      </div>
      <div
        style="border-left:2px solid var(--border-2);padding-left:26px;margin-left:6px"
      >
        {
          ventures.map((job) => (
            <div style="position:relative;padding:0 0 24px">
              <svg
                viewBox="0 0 100 100"
                style="position:absolute;left:-36px;top:1px;width:18px;height:18px;--leaf:var(--accent);filter:drop-shadow(0 0 6px var(--accent))"
              >
                <use href="#ivy-leaf" />
              </svg>
              <div style="font-family:var(--f-mono);font-size:11.5px;color:var(--accent);margin-bottom:4px">
                {job.years}
              </div>
              <div style="font-family:var(--f-display);font-size:18px">
                {job.role}{" "}
                <span style="color:var(--text-faint)">· {job.org}</span>
              </div>
              <p style="color:var(--text-dim);margin:6px 0 0;font-size:13.5px;line-height:1.6">
                {job.note}
              </p>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</div>
