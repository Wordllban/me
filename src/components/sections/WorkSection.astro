---
import SectionHeader from "./SectionHeader.astro";
import { projects } from "../../data/portfolio";
---

<div class="section" data-section="work">
  <SectionHeader
    title="Things I've planted."
    rune="III · The Workshop"
    marginBottom="20px"
  />
  <div
    data-body
    style="flex:1;min-height:0;overflow-y:auto;padding-right:6px;display:flex;flex-direction:column;gap:16px"
  >
    <article
      style="position:relative;border:1px solid var(--border);border-radius:var(--radius);background:var(--panel);padding:clamp(20px,2.6vw,30px);box-shadow:var(--shadow)"
      class="tt"
    >
      <span
        style="position:absolute;top:10px;left:10px;width:13px;height:13px;border-top:2px solid var(--accent-2);border-left:2px solid var(--accent-2);opacity:var(--bracket-op)"
      ></span>
      <span
        style="position:absolute;bottom:10px;right:10px;width:13px;height:13px;border-bottom:2px solid var(--accent-2);border-right:2px solid var(--accent-2);opacity:var(--bracket-op)"
      ></span>
      <div style="display:flex;align-items:center;gap:10px;margin-bottom:12px">
        <svg viewBox="0 0 100 100" style="width:22px;height:22px"
          ><use href="#ivy-leaf"></use></svg
        >
        <span style="font-family:var(--f-display);font-size:22px">Ivy</span>
        <span
          style="font-family:var(--f-mono);font-size:10.5px;padding:4px 9px;border-radius:999px;background:var(--accent);color:#140b1c;font-weight:600"
          >CO-FOUNDER</span
        >
      </div>
      <p
        style="color:var(--text-dim);margin:0 0 14px;line-height:1.65;max-width:62ch"
      >
        My startup — a freelance, commission &amp; community platform for every
        form of art, giving clients and artists every tool to find each other
        and work together in one place. Open beta arrives this summer.
      </p>
      <a
        href="https://ivyart.co/"
        target="_blank"
        rel="noopener"
        style="font-family:var(--f-mono);font-size:12.5px;color:var(--accent-2);text-decoration:none"
        >join the open beta →</a
      >
    </article>
    <div
      data-work-grid
      style="display:grid;grid-template-columns:repeat(3,1fr);gap:14px"
    >
      {
        projects.map((p) => (
          <article
            class="work-card tt"
            style="position:relative;border:1px solid var(--border);border-radius:var(--radius);background:var(--panel);padding:18px;display:flex;flex-direction:column;gap:8px"
          >
            <div style="display:flex;align-items:center;justify-content:space-between">
              <span style="font-family:var(--f-mono);font-size:10.5px;color:var(--accent-2)">
                {p.tag}
              </span>
              <span style="font-size:18px">{p.emoji}</span>
            </div>
            <h3 style="font-family:var(--f-display);font-size:18px;margin:0">
              {p.name}
            </h3>
            <p style="color:var(--text-dim);font-size:13px;margin:0;line-height:1.5">
              {p.note}
            </p>
            {p.href && (
              <>
                <span style="font-family:var(--f-mono);font-size:11px;color:var(--accent-2);margin-top:2px">
                  open repo ↗
                </span>
                <a
                  href={p.href}
                  target="_blank"
                  rel="noopener"
                  aria-label={p.name}
                  style="position:absolute;inset:0;border-radius:var(--radius)"
                />
              </>
            )}
          </article>
        ))
      }
    </div>
  </div>
</div>
