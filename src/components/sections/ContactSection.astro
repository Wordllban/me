---
import SectionHeader from "./SectionHeader.astro";
import { channels } from "../../data/portfolio";

const discordPath =
  "M20.317 4.3698a19.7913 19.7913 0 00-4.8851-1.5152.0741.0741 0 00-.0785.0371c-.211.3753-.4447.8648-.6083 1.2495-1.8447-.2762-3.68-.2762-5.4868 0-.1636-.3933-.4058-.8742-.6177-1.2495a.077.077 0 00-.0785-.037 19.7363 19.7363 0 00-4.8852 1.515.0699.0699 0 00-.0321.0277C.5334 9.0458-.319 13.5799.0992 18.0578a.0824.0824 0 00.0312.0561c2.0528 1.5076 4.0413 2.4228 5.9929 3.0294a.0777.0777 0 00.0842-.0276c.4616-.6304.8731-1.2952 1.226-1.9942a.076.076 0 00-.0416-.1057c-.6528-.2476-1.2743-.5495-1.8722-.8923a.077.077 0 01-.0076-.1277c.1258-.0943.2517-.1923.3718-.2914a.0743.0743 0 01.0776-.0105c3.9278 1.7933 8.18 1.7933 12.0614 0a.0739.0739 0 01.0785.0095c.1202.099.246.1981.3728.2924a.077.077 0 01-.0066.1276 12.2986 12.2986 0 01-1.873.8914.0766.0766 0 00-.0407.1067c.3604.698.7719 1.3628 1.225 1.9932a.076.076 0 00.0842.0286c1.961-.6067 3.9495-1.5219 6.0023-3.0294a.077.077 0 00.0313-.0552c.5004-5.177-.8382-9.6739-3.5485-13.6604a.061.061 0 00-.0312-.0286zM8.02 15.3312c-1.1825 0-2.1569-1.0857-2.1569-2.419 0-1.3332.9555-2.4189 2.157-2.4189 1.2108 0 2.1757 1.0952 2.1568 2.419 0 1.3332-.9555 2.4189-2.1569 2.4189zm7.9748 0c-1.1825 0-2.1569-1.0857-2.1569-2.419 0-1.3332.9554-2.4189 2.1569-2.4189 1.2108 0 2.1757 1.0952 2.1568 2.419 0 1.3332-.946 2.4189-2.1568 2.4189Z";

const markBase =
  "flex:0 0 40px;width:40px;height:40px;display:grid;place-items:center;border-radius:var(--radius);border:1px solid var(--border);background:rgba(124,77,255,.08);font-family:var(--f-display);font-weight:600;font-size:17px;letter-spacing:0";
---

<div class="section" data-section="contact">
  <SectionHeader
    title="Let's grow something."
    rune="VII · The Hearth"
    marginBottom="20px"
  />
  <div
    data-body
    style="flex:1;min-height:0;overflow-y:auto;overflow-x:hidden;padding-right:6px;display:flex;flex-direction:column;gap:clamp(14px,2vh,22px)"
  >
    <div
      data-contact-grid
      data-contact-inner
      style="flex:1;min-height:0;display:grid;grid-template-columns:1.04fr .96fr;gap:clamp(16px,1.8vw,24px);align-items:stretch"
    >
      <!-- left : invitation + summons + CV -->
      <div
        style="position:relative;border:1px solid var(--border);border-radius:var(--radius);background:linear-gradient(180deg,rgba(124,77,255,.10),rgba(28,20,42,.45));padding:clamp(22px,2.6vw,34px);overflow:hidden;display:flex;flex-direction:column"
        class="tt"
      >
        <span
          style="position:absolute;top:-34px;left:-24px;width:150px;height:150px;background:radial-gradient(circle,var(--glow1),transparent 70%);opacity:.7;pointer-events:none"
        ></span>
        <span
          style="position:absolute;bottom:-46px;right:-16px;width:170px;height:170px;background:radial-gradient(circle,var(--glow2),transparent 70%);opacity:.7;pointer-events:none"
        ></span>
        <span
          style="position:absolute;top:11px;left:11px;width:14px;height:14px;border-top:1.5px solid var(--gold);border-left:1.5px solid var(--gold);opacity:var(--bracket-op)"
        ></span>
        <span
          style="position:absolute;bottom:11px;right:11px;width:14px;height:14px;border-bottom:1.5px solid var(--gold);border-right:1.5px solid var(--gold);opacity:var(--bracket-op)"
        ></span>

        <div
          style="position:relative;display:flex;flex-direction:column;height:100%"
        >
          <div
            style="display:flex;align-items:center;gap:11px;margin-bottom:14px"
          >
            <span
              style="position:relative;display:inline-grid;place-items:center;width:46px;height:46px;flex:0 0 auto"
            >
              <span
                style="position:absolute;inset:-6px;border-radius:50%;background:radial-gradient(circle,var(--glow1),transparent 68%);animation:haze 3.4s ease-in-out infinite"
              ></span>
              <svg
                viewBox="0 0 100 100"
                style="position:relative;width:40px;height:40px;filter:drop-shadow(0 0 9px var(--leaf))"
                ><use href="#ivy-leaf"></use></svg
              >
            </span>
            <div
              style="font-family:var(--f-mono);font-size:10px;letter-spacing:.22em;text-transform:uppercase;color:var(--gold)"
            >
              Light the hearth
            </div>
          </div>

          <p
            style="color:var(--text-dim);margin:0 0 20px;line-height:1.62;font-size:15px;max-width:54ch"
          >
            Whether it's the
            <strong style="color:var(--text);font-weight:600;font-style:italic"
              >Ivy</strong
            > open beta, a collaboration, or trading bonsai tips — my inbox is always
            open.
          </p>

          <a
            href="mailto:mininkov1337@gmail.com"
            class="email-row tt"
            style="text-decoration:none;display:flex;align-items:center;gap:13px;padding:15px 18px;border-radius:var(--radius);border:1px solid var(--border-2);background:rgba(124,77,255,.10);margin-bottom:18px"
          >
            <span
              style="width:9px;height:9px;border-radius:50%;background:var(--gold);box-shadow:0 0 11px var(--gold);animation:pulse 2.4s ease-in-out infinite;flex:0 0 auto"
            ></span>
            <span style="display:flex;flex-direction:column;min-width:0">
              <span
                style="font-family:var(--f-mono);font-size:9.5px;letter-spacing:.14em;text-transform:uppercase;color:var(--text-faint)"
                >Primary raven</span
              >
              <span
                style="font-family:var(--f-display);font-size:clamp(15px,1.6vw,19px);letter-spacing:.01em;color:var(--text)"
                >mininkov1337@gmail.com</span
              >
            </span>
            <span
              style="margin-left:auto;color:var(--accent-2);font-family:var(--f-mono);font-size:15px"
              >↗</span
            >
          </a>

          <div
            style="margin-top:auto;position:relative;display:flex;align-items:center;gap:clamp(20px,2.6vw,34px);padding:clamp(18px,2.1vw,26px) clamp(20px,2.3vw,28px);border-radius:var(--radius);border:1px solid var(--border-2);background:linear-gradient(180deg,rgba(124,77,255,.12),rgba(28,20,42,.5))"
          >
            <!-- faux CV page preview -->
            <div
              style="flex:0 0 auto;width:72px;height:96px;transform:rotate(-3deg);border-radius:4px;border:1px solid var(--border);background:linear-gradient(180deg,#221733,#191024);box-shadow:0 14px 30px -10px rgba(0,0,0,.7);padding:11px 9px;display:flex;flex-direction:column;gap:6px;overflow:hidden"
            >
              <span
                style="width:60%;height:6px;border-radius:2px;background:var(--gold);opacity:.85"
              ></span>
              <span
                style="width:90%;height:3px;border-radius:2px;background:var(--text-faint);opacity:.55"
              ></span>
              <span
                style="width:80%;height:3px;border-radius:2px;background:var(--text-faint);opacity:.4"
              ></span>
              <span
                style="width:88%;height:3px;border-radius:2px;background:var(--text-faint);opacity:.4"
              ></span>
              <span
                style="width:55%;height:3px;border-radius:2px;background:var(--accent);opacity:.55;margin-top:3px"
              ></span>
              <span
                style="width:84%;height:3px;border-radius:2px;background:var(--text-faint);opacity:.35"
              ></span>
              <span
                style="width:70%;height:3px;border-radius:2px;background:var(--text-faint);opacity:.35"
              ></span>
            </div>
            <div
              style="display:flex;flex-direction:column;gap:7px;min-width:0;flex:1"
            >
              <span
                style="font-family:var(--f-mono);font-size:9.5px;letter-spacing:.18em;text-transform:uppercase;color:var(--gold)"
                >Curriculum Vitae</span
              >
              <span
                style="font-family:var(--f-display);font-weight:600;font-size:clamp(17px,1.8vw,20px);color:var(--text);line-height:1.12"
                >The full résumé</span
              >
              <span
                style="font-family:var(--f-mono);font-size:10px;color:var(--text-faint);letter-spacing:.03em;margin-bottom:15px"
                >PDF · Kostiantyn Mininkov · 4 pages</span
              >
              <a
                href="/assets/kostiantyn-mininkov-cv.pdf"
                download
                class="cv-btn tt"
                style="position:relative;overflow:hidden;text-decoration:none;display:inline-flex;align-items:center;justify-content:center;gap:10px;padding:13px 22px 13px 18px;border-radius:var(--radius);background:linear-gradient(180deg,#9f56f5,#7e3fd6);color:#f4ecff;border:1px solid rgba(216,180,106,.5);font-family:var(--f-display);font-weight:600;font-size:14px;letter-spacing:.03em;align-self:flex-start;box-shadow:0 1px 0 rgba(255,255,255,.12) inset,0 10px 24px -12px rgba(110,50,200,.9),0 0 0 0 rgba(216,180,106,0)"
              >
                <svg
                  viewBox="0 0 100 100"
                  style="position:relative;width:17px;height:17px;flex:0 0 auto;filter:drop-shadow(0 0 5px var(--gold));--leaf:var(--gold);--vein:rgba(255,255,255,.5)"
                  ><use href="#ivy-leaf"></use></svg
                >
                <span style="position:relative">Download CV</span>
                <span
                  style="position:relative;font-family:var(--f-mono);font-size:13px;color:var(--gold)"
                  >↓</span
                >
              </a>
            </div>
          </div>
        </div>
      </div>

      <!-- right : channels -->
      <div
        style="display:flex;flex-direction:column;gap:clamp(10px,1.3vh,15px);padding-right:6px"
      >
        <div
          style="font-family:var(--f-mono);font-size:10px;letter-spacing:.2em;text-transform:uppercase;color:var(--text-faint);padding:2px 4px 0"
        >
          Find me across the realm
        </div>
        {
          channels.map((c) => (
            <a
              data-ch-row
              class="channel-row tt"
              href={c.href}
              target="_blank"
              rel="noopener"
              style="display:flex;align-items:center;gap:14px;text-decoration:none;padding:15px 18px;border:1px solid var(--border);border-radius:var(--radius);background:var(--panel)"
            >
              <span
                style={`${markBase};color:${c.markColor}${c.mono ? ";font-family:var(--f-mono);font-size:12px" : ""}`}
              >
                {c.glyph === "discord" ? (
                  <svg
                    width="20"
                    height="20"
                    viewBox="0 0 24 24"
                    fill="currentColor"
                    aria-hidden="true"
                  >
                    <path d={discordPath} />
                  </svg>
                ) : (
                  c.glyph
                )}
              </span>
              <span style="display:flex;flex-direction:column;min-width:0;flex:1">
                <span style="font-family:var(--f-display);font-size:17px;letter-spacing:.01em;color:var(--text)">
                  {c.name}
                </span>
                <span style="font-family:var(--f-mono);font-size:11.5px;color:var(--text-dim);letter-spacing:.01em;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">
                  {c.handle}
                </span>
              </span>
              <span style="font-family:var(--f-mono);font-size:10px;letter-spacing:.1em;text-transform:uppercase;color:var(--text-faint);white-space:nowrap">
                {c.tag}
              </span>
              <span style="color:var(--accent-2);font-family:var(--f-mono);font-size:14px;flex:0 0 auto">
                ↗
              </span>
            </a>
          ))
        }
      </div>
    </div>

    <div
      style="flex:0 0 auto;display:flex;align-items:center;justify-content:space-between;gap:16px;flex-wrap:wrap;font-family:var(--f-mono);font-size:11px;color:var(--text-faint);border-top:1px solid var(--border);padding-top:16px"
    >
      <span style="display:flex;align-items:center;gap:8px">
        <span
          style="width:8px;height:8px;border-radius:50%;background:var(--gold);box-shadow:0 0 10px var(--gold);animation:pulse 2.4s ease-in-out infinite"
        ></span>open to quests · Lviv, UA · EET
      </span>
      <span>© 2026 Kostiantyn Mininkov — grown with ivy &amp; intent</span>
    </div>
  </div>
</div>
