---
import SectionHeader from "./SectionHeader.astro";
import { sanctum } from "../../data/portfolio";

const defaultOpen = "garden";
---

<div class="section" data-section="corner">
  <SectionHeader
    title="The stuff that makes me, me."
    rune="VI · The Sanctum"
    marginBottom="6px"
  />
  <p style="color:var(--text-dim);margin:0 0 18px;flex:0 0 auto">
    A portfolio should have a heartbeat. Here's mine.
  </p>
  <div
    data-body
    data-corner-body
    style="flex:1;min-height:0;overflow:hidden;padding-right:6px;display:grid;grid-template-columns:repeat(2,1fr);grid-auto-rows:1fr;grid-auto-flow:row dense;gap:16px;align-content:stretch"
  >
    {
      sanctum.map((c) => (
        <article
          class="sanctum-card"
          data-sanctum-card={c.key}
          data-roll={c.roll ? "" : undefined}
          data-open={c.key === defaultOpen ? "" : undefined}
        >
          <div class="sanctum-id" data-sanctum-toggle>
            <div style="display:flex;align-items:center;gap:11px;margin-bottom:11px">
              <span style="font-size:26px;line-height:1">{c.emoji}</span>
              <h3 style="font-family:var(--f-display);font-size:19px;margin:0;line-height:1.1">
                {c.title}
              </h3>
            </div>
            <p style="color:var(--text-dim);font-size:13.5px;margin:0;line-height:1.6;flex:0 1 auto;overflow:hidden">
              {c.desc}
            </p>
            <div style="margin-top:auto;padding-top:12px;display:flex;align-items:center;justify-content:space-between;gap:10px">
              <span
                data-sanctum-meta
                style={`font-family:var(--f-mono);font-size:11px;color:${c.roll ? "var(--accent-2)" : "var(--text-faint)"};cursor:${c.roll ? "pointer" : "default"};user-select:none`}
              >
                {c.meta}
              </span>
              <span class="sanctum-cue" data-sanctum-cue>
                {c.key === defaultOpen ? "✕ close" : "⤢ open"}
              </span>
            </div>
          </div>
          <div class="sanctum-wells">
            <div class="sanctum-well sanctum-well-1">{c.ph[0]}</div>
            <div class="sanctum-well sanctum-well-2">{c.ph[1]}</div>
            <div class="sanctum-well sanctum-well-3">{c.ph[2]}</div>
          </div>
        </article>
      ))
    }
  </div>
</div>
