---
import SectionHeader from "./SectionHeader.astro";
import { education, accolades, course, wins } from "../../data/portfolio";
---

<div class="section" data-section="wins">
  <SectionHeader
    title="Little wins, shared out loud."
    rune="V · The Chronicle"
    marginBottom="6px"
  />
  <p
    data-wins-intro
    style="color:var(--text-dim);margin:0 0 18px;flex:0 0 auto;white-space:nowrap"
  >
    Trials passed, tomes studied, milestones shared out loud. 🌱
  </p>
  <div
    data-body
    style="flex:1;min-height:0;overflow-y:auto;padding-right:6px;display:flex;flex-direction:column;gap:18px"
  >
    <!-- The Academy -->
    <div style="display:flex;align-items:center;gap:12px">
      <svg
        viewBox="0 0 100 100"
        style="width:16px;height:16px;flex:0 0 auto;filter:drop-shadow(0 0 6px var(--leaf))"
        ><use href="#ivy-leaf"></use></svg
      >
      <span
        style="font-family:var(--f-mono);font-size:10px;letter-spacing:.22em;text-transform:uppercase;color:var(--gold)"
        >The Academy · schooling &amp; scrolls</span
      >
      <span
        style="flex:1;height:1px;background:linear-gradient(90deg,var(--border),transparent)"
      ></span>
    </div>

    <!-- university tome -->
    <article
      style="position:relative;border:1px solid var(--border);border-radius:var(--radius);background:var(--panel);padding:clamp(18px,2.2vw,26px);box-shadow:var(--shadow)"
      class="tt"
    >
      <span
        style="position:absolute;top:10px;left:10px;width:13px;height:13px;border-top:2px solid var(--gold);border-left:2px solid var(--gold);opacity:var(--bracket-op)"
      ></span>
      <span
        style="position:absolute;bottom:10px;right:10px;width:13px;height:13px;border-bottom:2px solid var(--gold);border-right:2px solid var(--gold);opacity:var(--bracket-op)"
      ></span>
      <div
        style="display:flex;align-items:flex-start;justify-content:space-between;gap:16px;margin-bottom:16px;flex-wrap:wrap"
      >
        <div style="display:flex;align-items:flex-start;gap:13px;min-width:0">
          <svg
            viewBox="0 0 100 100"
            style="width:26px;height:26px;flex:0 0 auto;margin-top:2px;filter:drop-shadow(0 0 7px var(--leaf))"
            ><use href="#ivy-leaf"></use></svg
          >
          <div style="min-width:0">
            <div
              style="font-family:var(--f-mono);font-size:9.5px;letter-spacing:.16em;text-transform:uppercase;color:var(--accent-2);margin-bottom:5px"
            >
              {education.degree}
            </div>
            <h3
              style="font-family:var(--f-display);font-size:clamp(18px,2vw,22px);margin:0 0 4px;line-height:1.15"
            >
              {education.field}
            </h3>
            <div style="color:var(--text-dim);font-size:14px">
              {education.school}
            </div>
          </div>
        </div>
        <div
          style="flex:0 0 auto;display:flex;flex-direction:column;align-items:center;gap:3px;padding:9px 16px;border-radius:var(--radius);border:1px solid var(--border-2);background:linear-gradient(180deg,rgba(124,77,255,.14),transparent)"
        >
          <span
            style="font-family:var(--f-mono);font-size:8.5px;letter-spacing:.14em;text-transform:uppercase;color:var(--text-faint)"
            >Grade</span
          >
          <span
            style="font-family:var(--f-display);font-weight:600;font-size:20px;color:var(--text);line-height:1"
            >{education.grade}</span
          >
        </div>
      </div>
      <div
        style="font-family:var(--f-mono);font-size:9.5px;letter-spacing:.14em;text-transform:uppercase;color:var(--text-faint);margin-bottom:9px"
      >
        Tomes studied
      </div>
      <div style="display:flex;flex-wrap:wrap;gap:7px">
        {
          education.courses.map((c) => (
            <span style="font-family:var(--f-mono);font-size:11px;padding:5px 11px;border-radius:999px;background:var(--chip-bg);border:1px solid var(--border);color:var(--text-dim)">
              {c}
            </span>
          ))
        }
      </div>
    </article>

    <!-- accelerator victories -->
    <div
      data-accolades-grid
      style="display:grid;grid-template-columns:repeat(2,1fr);gap:14px"
    >
      {
        accolades.map((a) => (
          <article
            class="tt"
            style="position:relative;display:flex;align-items:center;gap:14px;border:1px solid var(--border);border-radius:var(--radius);background:linear-gradient(180deg,rgba(216,180,106,.10),rgba(28,20,42,.4));padding:16px 18px"
          >
            <span style="flex:0 0 auto;width:40px;height:40px;display:grid;place-items:center;border-radius:var(--radius);border:1px solid var(--border);background:rgba(216,180,106,.10);font-size:20px">
              {a.emoji}
            </span>
            <div style="min-width:0;flex:1">
              <div style="font-family:var(--f-mono);font-size:9.5px;letter-spacing:.1em;text-transform:uppercase;color:var(--gold);margin-bottom:4px">
                {a.kind}
              </div>
              <div style="font-family:var(--f-display);font-size:17px;line-height:1.15;color:var(--text)">
                {a.title}
              </div>
            </div>
            <span style="flex:0 0 auto;font-family:var(--f-mono);font-size:12px;color:var(--accent-2)">
              {a.year}
            </span>
          </article>
        ))
      }
    </div>

    <!-- course -->
    <article
      class="tt"
      style="position:relative;border:1px solid var(--border);border-radius:var(--radius);background:var(--panel);padding:18px 20px"
    >
      <div style="display:flex;align-items:center;gap:10px;margin-bottom:8px">
        <span style="font-size:18px">☁️</span>
        <span
          style="font-family:var(--f-mono);font-size:9.5px;letter-spacing:.12em;text-transform:uppercase;color:var(--accent-2)"
          >{course.kind}</span
        >
      </div>
      <h3
        style="font-family:var(--f-display);font-size:18px;margin:0 0 8px;line-height:1.2"
      >
        {course.title}
      </h3>
      <p
        style="color:var(--text-dim);font-size:13.5px;margin:0;line-height:1.6;max-width:74ch"
      >
        {course.note}
      </p>
    </article>

    <!-- Milestones -->
    <div style="display:flex;align-items:center;gap:12px;margin-top:4px">
      <svg
        viewBox="0 0 100 100"
        style="width:16px;height:16px;flex:0 0 auto;filter:drop-shadow(0 0 6px var(--leaf))"
        ><use href="#ivy-leaf"></use></svg
      >
      <span
        style="font-family:var(--f-mono);font-size:10px;letter-spacing:.22em;text-transform:uppercase;color:var(--gold)"
        >Milestones · little wins</span
      >
      <span
        style="flex:1;height:1px;background:linear-gradient(90deg,var(--border),transparent)"
      ></span>
    </div>

    {
      wins.map((w) => (
        <article
          class="tt"
          style="display:grid;grid-template-columns:auto 1fr;gap:16px;align-items:center;border:1px solid var(--border);border-radius:var(--radius);background:var(--panel);padding:15px 20px"
        >
          <div style="font-family:var(--f-mono);font-size:11.5px;color:var(--accent);text-align:center;padding-right:16px;border-right:1px solid var(--border);min-width:62px">
            {w.date}
          </div>
          <div style="display:flex;align-items:center;gap:13px">
            <span style="font-size:20px">{w.emoji}</span>
            <div>
              <div style="font-weight:600">{w.title}</div>
              <div style="color:var(--text-dim);font-size:13.5px">{w.note}</div>
            </div>
          </div>
        </article>
      ))
    }
  </div>
</div>
