---
interface Props {
  title: string;
  rune: string;
  marginBottom?: string;
}
const { title, rune, marginBottom = "18px" } = Astro.props;
---

<div
  style={`display:flex;align-items:baseline;justify-content:space-between;gap:16px;margin-bottom:${marginBottom};flex:0 0 auto`}
>
  <h2
    style="font-family:var(--f-display);font-weight:600;font-size:clamp(24px,3vw,38px);margin:0;letter-spacing:-.01em"
  >
    <slot name="title">{title}</slot>
  </h2>
  <span
    style="font-family:var(--f-mono);font-size:12px;color:var(--gold);white-space:nowrap"
    >{rune}</span
  >
</div>
