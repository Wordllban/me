---
// Mobile / tablet navigation: a "page-turner" bar (prev · current chapter · next)
// plus a jump-to-chapter bottom sheet. Hidden on desktop via CSS ([data-bottomnav]).
import { sectionMeta } from "../data/portfolio";

const activeKey = "about";
const cur = sectionMeta.find((m) => m.key === activeKey) ?? sectionMeta[0];
---

<!-- page-turner nav -->
<nav
  data-bottomnav
  aria-label="Browse sections"
  class="tt"
  style="position:relative;z-index:30;align-items:center;gap:10px;padding:8px 14px max(8px,env(safe-area-inset-bottom));border-top:1px solid var(--border);background:linear-gradient(180deg,rgba(13,9,21,.9),rgba(8,5,13,.98));flex:0 0 auto"
>
  <button
    data-pager-prev
    class="pager-btn"
    aria-label="Previous chapter"
    style="position:relative;display:grid;place-items:center;width:48px;height:48px;flex:0 0 auto;border-radius:50%;border:1px solid var(--border-2);background:radial-gradient(circle at 50% 36%,rgba(255,255,255,.055),rgba(255,255,255,.008));cursor:pointer;color:var(--gold);transition:border-color .3s ease,box-shadow .3s ease,transform .18s ease;-webkit-tap-highlight-color:transparent"
  >
    <span
      style="position:absolute;inset:-4px;border-radius:50%;border:1px dashed var(--border-2);opacity:.5;animation:navspin 14s linear infinite reverse;pointer-events:none"
    ></span>
    <svg
      viewBox="0 0 24 24"
      width="21"
      height="21"
      fill="none"
      style="position:relative;transform:scaleX(-1);filter:drop-shadow(0 0 5px var(--gold))"
    >
      <path
        d="M9.5 5 L16.5 12 L9.5 19"
        stroke="var(--gold)"
        stroke-width="2.2"
        stroke-linecap="round"
        stroke-linejoin="round"></path>
      <circle cx="16.5" cy="12" r="1.5" fill="var(--gold)"></circle>
    </svg>
  </button>

  <button
    data-pager-toggle
    aria-label="Jump to chapter"
    style="position:relative;flex:1 1 auto;min-width:0;display:flex;flex-direction:column;align-items:center;gap:8px;padding:4px 8px;border:none;background:transparent;cursor:pointer;color:inherit;-webkit-tap-highlight-color:transparent"
  >
    <span
      style="display:flex;align-items:center;gap:9px;width:100%;justify-content:center"
    >
      <span
        style="flex:1 1 0;height:1px;max-width:32px;background:linear-gradient(90deg,transparent,var(--border-2))"
      ></span>
      <span
        data-pager-numeral
        style="display:inline-grid;place-items:center;width:23px;height:23px;flex:0 0 auto;font-family:var(--f-display);font-size:11px;color:var(--gold);border:1px solid var(--border-2);border-radius:50%;letter-spacing:.02em;box-shadow:inset 0 0 8px -4px var(--gold)"
        >{cur.n}</span
      >
      <span
        data-pager-label
        style="font-family:var(--f-display);font-size:16px;letter-spacing:.03em;color:var(--text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;min-width:0"
        >{cur.label}</span
      >
      <span
        style="flex:1 1 0;height:1px;max-width:32px;background:linear-gradient(90deg,var(--border-2),transparent)"
      ></span>
    </span>
    <span style="display:flex;align-items:center;gap:5px">
      {
        sectionMeta.map((m) => (
          <span
            class="pager-dot"
            data-pager-dot={m.key}
            data-active={m.key === activeKey ? "" : undefined}
          />
        ))
      }
    </span>
  </button>

  <button
    data-pager-next
    class="pager-btn"
    aria-label="Next chapter"
    style="position:relative;display:grid;place-items:center;width:48px;height:48px;flex:0 0 auto;border-radius:50%;border:1px solid var(--border-2);background:radial-gradient(circle at 50% 36%,rgba(255,255,255,.055),rgba(255,255,255,.008));cursor:pointer;color:var(--gold);transition:border-color .3s ease,box-shadow .3s ease,transform .18s ease;-webkit-tap-highlight-color:transparent"
  >
    <span
      style="position:absolute;inset:-4px;border-radius:50%;border:1px dashed var(--border-2);opacity:.5;animation:navspin 14s linear infinite;pointer-events:none"
    ></span>
    <svg
      viewBox="0 0 24 24"
      width="21"
      height="21"
      fill="none"
      style="position:relative;filter:drop-shadow(0 0 5px var(--gold))"
    >
      <path
        d="M9.5 5 L16.5 12 L9.5 19"
        stroke="var(--gold)"
        stroke-width="2.2"
        stroke-linecap="round"
        stroke-linejoin="round"></path>
      <circle cx="16.5" cy="12" r="1.5" fill="var(--gold)"></circle>
    </svg>
  </button>
</nav>

<!-- jump-to-chapter bottom sheet -->
<div data-nav-sheet class="nav-sheet">
  <div
    data-nav-panel
    style="position:relative;background:var(--panel);border-top:1px solid var(--border-2);border-radius:20px 20px 0 0;padding:10px 14px max(18px,env(safe-area-inset-bottom));box-shadow:0 -18px 50px -20px #000;max-height:74vh;overflow-y:auto"
  >
    <div
      style="display:flex;align-items:center;justify-content:space-between;padding:8px 12px 12px"
    >
      <span
        style="font-family:var(--f-mono);font-size:10px;letter-spacing:.22em;text-transform:uppercase;color:var(--gold)"
        >Choose a chapter</span
      >
      <button
        data-nav-close
        aria-label="Close"
        style="width:32px;height:32px;display:grid;place-items:center;border-radius:9px;border:1px solid var(--border);background:rgba(255,255,255,.02);cursor:pointer;color:var(--text-dim);font-size:15px"
        >✕</button
      >
    </div>
    {
      sectionMeta.map((m, i) => (
        <button
          class="nav-row"
          data-nav-row={m.key}
          data-active={m.key === activeKey ? "" : undefined}
        >
          <span class="nav-row-n">{m.n}</span>
          <svg
            viewBox="0 0 100 100"
            class="nav-row-leaf"
            style={`transform:rotate(${i % 2 ? 8 : -8}deg)`}
          >
            <use href="#ivy-leaf" />
          </svg>
          <span style="display:flex;flex-direction:column;gap:3px;min-width:0">
            <span class="nav-row-label">{m.label}</span>
            <span class="nav-row-desc">{m.desc}</span>
          </span>
        </button>
      ))
    }
  </div>
</div>
